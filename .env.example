# Copy this file to .env and fill in your values

# Discord bot token — Discord Developer Portal → Your App → Bot → Token
DISCORD_TOKEN=your_discord_bot_token_here

# PokeWallet API key — https://pokewallet.io → API Keys
POKEWALLET_KEY=your_pokewallet_api_key_here

# Discord forum channel ID where card posts are created
# Right-click the channel in Discord → Copy Channel ID (requires Developer Mode)
FORUM_CHANNEL_ID=your_forum_channel_id_here

# Text channel ID where the persistent Search Card button is posted
# Right-click the channel in Discord → Copy Channel ID (requires Developer Mode)
SEARCH_CHANNEL_ID=your_search_channel_id_here
